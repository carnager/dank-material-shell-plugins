pkgname=dms-plugin-mpd-browser
pkgver="$(<VERSION)"
pkgrel=1
pkgdesc="Dedicated MPD album browser widget for Dank Material Shell"
arch=('any')
url="https://github.com/carnager/dank-material-shell-plugins"
license=('GPL')
depends=('mpdwatch')

package() {
  local dest="$pkgdir/etc/xdg/quickshell/dms-plugins/mpd-browser"

  install -d "$dest"
  cp -a "$startdir"/. "$dest/"

  rm -f "$dest/PKGBUILD" "$dest/default.nix" "$dest/VERSION"
  find "$dest" -name '__pycache__' -type d -exec rm -rf {} +
}
