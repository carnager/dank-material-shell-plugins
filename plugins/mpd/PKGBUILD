pkgname=dms-plugin-mpd
pkgver="$(<VERSION)"
pkgrel=1
pkgdesc="MPD track widget for Dank Material Shell"
arch=('any')
url="https://github.com/carnager/dank-material-shell-plugins"
license=('GPL')
depends=('mpdwatch')

package() {
  local dest="$pkgdir/etc/xdg/quickshell/dms-plugins/mpd"

  install -d "$dest"
  cp -a . "$dest/"

  rm -f "$dest/PKGBUILD" "$dest/default.nix" "$dest/VERSION"
  rm -f "$dest/clerk-api-rofi" "$dest/mpdwatch"
  find "$dest" -name '__pycache__' -type d -exec rm -rf {} +
}
