pkgname=dms-plugin-public-transport
pkgver="$(<VERSION)"
pkgrel=1
pkgdesc="Public transport widget for Dank Material Shell"
arch=('any')
url="https://github.com/carnager/dank-material-shell-plugins"
license=('GPL')
depends=('python')

package() {
  local dest="$pkgdir/etc/xdg/quickshell/dms-plugins/public-transport"

  install -d "$dest"
  cp -a "$startdir"/. "$dest/"

  rm -f "$dest/PKGBUILD" "$dest/default.nix" "$dest/VERSION"
  find "$dest" -name '__pycache__' -type d -exec rm -rf {} +
}
